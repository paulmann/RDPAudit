# RdpAudit repository line-ending policy.
#
# Roslyn enforces .editorconfig's `end_of_line = lf` at build time
# (EnforceCodeStyleInBuild=true). Without this file, Git on Windows with the
# default `core.autocrlf=true` converts LF to CRLF on checkout, which causes
# the analyzer to emit thousands of `ENDOFLINE` errors. Pinning eol=lf for
# all text files keeps the working tree consistent with the index.

# Default: treat unknown files as text and check them out with LF.
* text=auto eol=lf

# C# / MSBuild / solution: hard LF, hard text.
*.cs        text eol=lf
*.csproj    text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.sln       text eol=lf
*.editorconfig text eol=lf

# Config / data formats: LF.
*.json      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.manifest  text eol=lf

# PowerShell: keep LF in the repo (PowerShell 5.1+ on Windows reads both).
# This matches the existing on-disk format and avoids CRLF drift.
*.ps1       text eol=lf
*.psm1      text eol=lf
*.psd1      text eol=lf

# Shell / scripts.
*.sh        text eol=lf

# Binary assets must never be touched.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.7z        binary
*.dll       binary
*.exe       binary
*.pdb       binary
*.snk       binary
